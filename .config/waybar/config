{
  "position": "top",
  "height": 26,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "pulseaudio",
    "custom/mic",
    "bluetooth",
    "network",
    "battery",
    "clock",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "all-outputs": false,
    "persistent-workspaces": {
      "*": 5
    }
  },

  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true
  },

  "tray": {
    "spacing": 8
  },

  "clock": {
    "format": "{:%I:%M}",
    "format-alt": "{:%Y-%m-%d}",
    "tooltip": false
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¾░éä {capacity}%",
    "format-plugged": "¾░éä {capacity}%",
    "format-alt": "{time}",
